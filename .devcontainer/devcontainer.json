{
    "name": "GraphQL Countries Service - Kotlin/JVM",
    "dockerFile": "services/countries-service/Dockerfile",
    "context": "..",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.java",
                "vscjava.vscode-gradle",
                "fwcd.kotlin",
                "apollographql.vscode-apollo"
            ],
            "settings": {
                "java.server.launchMode": "Standard",
                "java.configuration.updateBuildConfiguration": "automatic",
                "java.configuration.runtimes": [
                    {
                        "name": "JavaSE-21",
                        "path": "/opt/java/openjdk",
                        "default": true
                    }
                ],
                "java.checkstyle.enable": false,
                "java.saveActions.organizeImports": true,
                "java.format.enabled": true,
                "java.format.settings.url": "",
                "java.codeGeneration.useBlocks": true,
                "java.home": "/opt/java/openjdk",
                "java.maven.downloadsources": false,
                "java.errors.incompleteClasspath.severity": "ignore",
                "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms512m -Dlog.protocol=false -Dlog.level=SEVERE",
                "redhat.telemetry.enabled": false,
                "[java]": {
                    "editor.defaultFormatter": "redhat.java",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.fixAll": "explicit"
                    }
                },
                "[kotlin]": {
                    "editor.defaultFormatter": "fwcd.kotlin",
                    "editor.formatOnSave": true
                },
                "kotlin.debugAdapter.enabled": true,
                "kotlin.linter": "ktlint",
                "gradle.autoRefresh": true,
                "gradle.nestedProjects": true,
                "gradle.ignorePattern": "**/build",
                "files.exclude": {
                    "**/.gradle": true,
                    "**/build": true,
                    "**/.classpath": true,
                    "**/.project": true,
                    "**/.settings": true,
                    "**/.factorypath": true
                },
                "search.exclude": {
                    "**/.gradle": true,
                    "**/build": true,
                    "**/.git": true
                },
                "files.watcherExclude": {
                    "**/.gradle": true,
                    "**/build": true,
                    "**/.vscode": true,
                    "**/.idea": true,
                    "**/.git": true,
                    "**/node_modules": true
                },
                "editor.formatOnSave": true,
                "editor.rulers": [
                    100,
                    120
                ],
                "editor.wordWrap": "on",
                "editor.insertSpaces": true,
                "editor.tabSize": 4,
                "editor.suggestSelection": "first",
                "editor.guides.bracketPairs": true,
                "editor.bracketPairColorization.enabled": true
            }
        }
    },
    "forwardPorts": [
        8080
    ],
    "portsAttributes": {
        "8080": {
            "label": "GraphQL Server",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "cd services/countries-service && gradle --version && kotlin -version && java -version && rm -rf ~/.gradle/jdks",
    "postStartCommand": "cd services/countries-service && gradle build -x test --quiet || true",
    "remoteUser": "vscode",
    "mounts": [
        "source=${localEnv:HOME}/.gradle,target=/home/vscode/.gradle,type=bind,consistency=cached"
    ]
}